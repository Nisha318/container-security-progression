# =============================================================================
# container-security-progression
# From Docker to EKS: A Security-First Progression
# =============================================================================

# =============================================================================
# PYTHON
# =============================================================================
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# =============================================================================
# ENVIRONMENT AND SECRETS
# Never commit secrets, credentials, or environment-specific config
# =============================================================================
.env
.env.*
*.env
.envrc

# AWS credentials -- should never be committed
.aws/
credentials

# =============================================================================
# DOCKER
# =============================================================================
# Local image exports (from docker export or docker save)
*.tar

# =============================================================================
# OPENTOFU / TERRAFORM
# =============================================================================

# Local .terraform and .tofu directories
.terraform/
.tofu/

# State files -- contain sensitive infrastructure data
*.tfstate
*.tfstate.*
*.tfstate.backup

# Crash logs
crash.log
crash.*.log

# Variable files -- likely contain sensitive values
*.tfvars
*.tfvars.json

# Override files -- used for local resource overrides, not for version control
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Transient lock info files
.terraform.tfstate.lock.info
.terraform.lock.hcl

# Plan output files
*.tfplan
tfplan

# CLI configuration files
.terraformrc
terraform.rc
.tofurc

# Graph output files
*.dot

# =============================================================================
# GITHUB ACTIONS -- local act runner artifacts
# =============================================================================
.act/

# =============================================================================
# TRIVY -- local scan output artifacts
# NOTE: .trivyignore is a compliance artifact and must stay in version control
# =============================================================================
trivy-results.txt
trivy-results.json
trivy-report.*

# =============================================================================
# CHECKOV -- local scan output artifacts
# =============================================================================
.checkov/
checkov-results.json
checkov-report.*

# =============================================================================
# GITLEAKS -- local scan output artifacts
# =============================================================================
gitleaks-report.json
gitleaks-report.*

# =============================================================================
# IDE
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace
*.iml

# =============================================================================
# OPERATING SYSTEM
# =============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# =============================================================================
# KUBERNETES -- local kubeconfig and sensitive artifacts (Stage 3)
# =============================================================================
kubeconfig
*.kubeconfig
.kube/

# Helm chart dependencies and build artifacts
charts/
*.tgz

# =============================================================================
# LOGS AND TEMPORARY FILES
# =============================================================================
*.log
*.tmp
*.temp
tmp/
temp/

# =============================================================================
# EXPLICITLY KEPT IN VERSION CONTROL
# The following are intentionally NOT excluded:
#   .trivyignore          -- compliance artifact documenting accepted CVE risk
#   compliance/*.md       -- NIST 800-53 mapping, CIS mapping, threat model
#   .dockerignore         -- build context exclusion rules
#   .github/workflows/    -- CI/CD pipeline definitions
# =============================================================================